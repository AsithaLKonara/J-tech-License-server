# Railway ignore file
# Files/directories to exclude from deployment

# Development files
.env
.env.*
!.env.example
!.env.production.example

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Test files
tests/
phpunit.xml
.phpunit.result.cache

# Documentation (optional - include if you want)
# docs/

# Git
.git/
.gitignore

# Node modules (if any)
node_modules/

